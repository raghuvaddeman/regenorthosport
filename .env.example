# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Airtable (legacy — being migrated to Supabase; leave blank to test login only)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Calls

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_CALLS_TABLE=calls

# Provider credential encryption (aes-256-gcm, 64-char hex string = 32 bytes)
ENCRYPTION_KEY=

# LiveKit Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret

# Vobiz Credentials (global SIP trunk — separate from per-tenant provider entries)
VOBIZ_SIP_DOMAIN=your-assigned-domain.sip.vobiz.ai
VOBIZ_USERNAME=your_trunk_username
VOBIZ_PASSWORD=your_trunk_password

# Shared secret for authenticating server-to-server / curl calls to
# /api/telephony (POST) via the `x-internal-secret` header. Leave unset to
# disable this bypass entirely and require a Clerk session for every call.
INTERNAL_SECRET_KEY=
